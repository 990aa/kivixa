  "packages": {
    "com.a990aa.kivixa": {
      "metadata": {
        "lastUpdated": 1775211591000,
        "summary": {
          "en-US": "A privacy-first cross-platform productivity workspace for notes, sketching, plan"
        },
        "description": {
          "en-US": "Kivixa is a privacy-first cross-platform productivity workspace for notes, sketching, planning, and local AI assistance..\n\nFeatures:\n- Rich markdown and text editing for fast note-taking\n- Digital canvas for handwriting, drawing, and mixed media notes\n- On-device AI with multi-model MCP workflows (no cloud required)\n- Knowledge graph view to connect ideas and topics visually\n- PDF reading and annotation inside the same workspace\n- Focus tools including Pomodoro and custom productivity timers\n- High-performance math tools powered by a Rust backend\n"
        }
      },
